# ===========================================
# Grzesiu E-com — zmienne środowiskowe
# ===========================================
# Skopiuj ten plik jako .env.local i uzupełnij wartości

# --- Użytkownik aplikacji ---
# 'hubert' — dostęp do seller scrapera i masowej edycji BL
# 'grzesiek' — podstawowy dostęp
APP_USER=hubert

# --- Anthropic / Claude (LLM — GŁÓWNE) ---
# Klucz Anthropic — WYMAGANY. Używany do:
# tłumaczeń, generowania opisów, tytułów, autofill, vision, Agent SDK, wariantów, kategorii
ANTHROPIC_API_KEY=

# Opcjonalne — nadpisanie modeli Claude dla poszczególnych funkcji
# (jeśli puste, kod używa wartości domyślnych wpisanych w route'ach)
# TITLE_MODEL=claude-haiku-4-5-20251001
# DESCRIPTION_MODEL=claude-sonnet-4-6
# AUTOFILL_MODEL=claude-haiku-4-5-20251001
# AGENT_MODEL=claude-haiku-4-5-20251001
# AGENT_VISION_MODEL=claude-sonnet-4-6

# --- BaseLinker ---
BASELINKER_TOKEN=

# --- Allegro (tokeny zarządzane automatycznie przez OAuth device flow) ---
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=

# --- Scraper ---
# Tryb: 'decodo' (domyślny), 'unblocker' (ScrapingBee) lub 'playwright' (lokalnie)
SCRAPER_MODE=decodo
SCRAPINGBEE_API_KEY=

# --- Decodo Web Scraping API (wymagane gdy SCRAPER_MODE=decodo) ---
DECODO_API_USERNAME=
DECODO_API_PASSWORD=

# --- Image Generation AI ---
FAL_KEY=
REMOVEBG_API_KEY=
REPLICATE_API_TOKEN=

# Opcjonalne — nadpisanie domyślnych modeli generowania obrazów
# FAL_MODEL_NANOBANANAPRO=fal-ai/nanobananapro
# FAL_MODEL_FLUXCONTEXTPRO=fal-ai/flux-pro/v1.1-ultra
# REPLICATE_MODEL_VERSION=

# --- Apify (ASIN→EAN konwersja) ---
APIFY_TOKEN=

# --- Google Sheets ---
GOOGLE_SHEETS_CREDENTIALS_PATH=./google-credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_GID=

# --- Cloudflare R2 (opcjonalne — cloud storage dla obrazów) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# --- Cloudinary (opcjonalne — alternatywny cloud storage) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
